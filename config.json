{
  "training": {
    "model_type": "maskrcnn",
    "pretrained": true,
    "data_path": "./detection",
    "output_dir": "./checkpoints",
    "epochs": 100,
    "lr_steps": [30, 60, 80],
    "lr_gamma": 0.1,
    "batch_size": 2,
    "workers": 4,
    "optimizer": "sgd",
    "learning_rate": 0.005,
    "momentum": 0.9,
    "weight_decay": 0.0001,
    "print_freq": 10,
    "save_freq": 5,
    "early_stopping_patience": 15,
    "gradient_clip_norm": 1.0
  },
  "augmentation": {
    "horizontal_flip_prob": 0.5,
    "random_rotation": true,
    "rotation_degrees": 15,
    "color_jitter": true,
    "brightness": 0.2,
    "contrast": 0.2,
    "saturation": 0.2,
    "hue": 0.1,
    "normalize": {
      "mean": [0.485, 0.456, 0.406],
      "std": [0.229, 0.224, 0.225]
    }
  },
  "model": {
    "backbone": "resnet50",
    "fpn_enabled": true,
    "num_classes": 2,
    "roi_batch_size_per_image": 512,
    "pos_fraction": 0.25,
    "score_thresh": 0.05,
    "nms_thresh": 0.5,
    "detections_per_image": 100,
    "rpn_fg_iou_thresh": 0.7,
    "rpn_bg_iou_thresh": 0.3,
    "rpn_num_samples": 256,
    "rpn_positive_fraction": 0.5,
    "rpn_pre_nms_top_n": {
      "train": 2000,
      "test": 1000
    },
    "rpn_post_nms_top_n": {
      "train": 2000,
      "test": 1000
    }
  },
  "inference": {
    "confidence_threshold": 0.5,
    "nms_threshold": 0.5,
    "max_detections_per_image": 100,
    "device": "cuda",
    "batch_size": 1,
    "mask_threshold": 0.5,
    "mask_area_min": 10
  },
  "regularization": {
    "dropout_rate": 0.5,
    "l2_regularization": 0.0001,
    "use_mixup": false,
    "mixup_alpha": 0.2,
    "label_smoothing": 0.0,
    "stochastic_depth": false
  },
  "evaluation": {
    "val_freq": 5,
    "metrics": ["mAP", "precision", "recall", "f1_score"],
    "iou_thresholds": [0.5, 0.75],
    "use_coco_metrics": true
  },
  "system": {
    "device": "cpu",
    "num_workers": 2,
    "pin_memory": false,
    "mixed_precision": false,
    "seed": 42,
    "cuda_benchmark": false
  },
  "data_subset": {
    "use_subset": false,
    "train_subset_size": 20,
    "test_subset_size": 10
  },
  "dataset": {
    "dataset_type": "detection",
    "image_format": "jpg",
    "mask_format": "png",
    "image_min_size": 512,
    "image_max_size": 1024,
    "aspect_ratio_group_factor": 3
  }
}
